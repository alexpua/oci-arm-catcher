# oci-arm-catcher configuration — copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Every value below is specific to YOUR Oracle Cloud tenancy. Nothing here is
# secret on its own (OCIDs are not credentials), but keep your real .env out of
# git anyway — it's already in .gitignore.
#
# Run ./scripts/get-config.sh (or scripts\get-config.ps1 on Windows) to print
# most of these values for you. See README.md for the manual steps too.

# Compartment to launch the instance in. The root compartment is your tenancy
# OCID; you can also use a child compartment.
#   oci iam compartment list --all
COMPARTMENT_ID="ocid1.tenancy.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Name shown for the instance in the OCI console.
DISPLAY_NAME="arm-free-1"

# Path to your SSH PUBLIC key (the .pub file). This key is added to the instance.
SSH_KEY_FILE="$HOME/.ssh/id_ed25519.pub"

# ── Availability Domain ───────────────────────────────────────────────────────
# Use ONE of the two options below.
#
# Option A — single AD:
AVAILABILITY_DOMAIN="Abcd:EU-AMSTERDAM-1-AD-1"
#
# Option B — rotate across several ADs each retry (comma-separated). If set,
# this takes precedence over AVAILABILITY_DOMAIN. Most regions only have AD-1,
# but multi-AD regions (e.g. Ashburn, Phoenix, Frankfurt) benefit from this.
# AVAILABILITY_DOMAINS="Abcd:EU-AMSTERDAM-1-AD-1,Abcd:EU-AMSTERDAM-1-AD-2,Abcd:EU-AMSTERDAM-1-AD-3"
#   List ADs:  oci iam availability-domain list

# Subnet to attach the VNIC to (must allow a public IP if you want one).
#   oci network subnet list --compartment-id <compartment> --all
SUBNET_ID="ocid1.subnet.oc1.eu-amsterdam-1.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# OS image to boot. Pick an aarch64/ARM image (e.g. Oracle Linux or Ubuntu ARM).
#   oci compute image list --compartment-id <compartment> \
#     --operating-system "Canonical Ubuntu" --shape VM.Standard.A1.Flex --all
IMAGE_ID="ocid1.image.oc1.eu-amsterdam-1.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Shape size. Always Free allowance is 4 OCPU + 24 GB total across A1 instances.
OCPUS=4
MEMORY_GB=24

# Seconds to wait between attempts. 300 (5 min) is polite and effective.
RETRY_INTERVAL=300
